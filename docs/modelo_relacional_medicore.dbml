Project MEDICORE {
  database_type: "MySQL"
  Note: "Modelo relacional do sistema MEDICORE para inventario hospitalar de equipamentos medicos."
}

Table utilizador_tipos {
  id int [pk, increment]
  nome varchar(50) [not null, unique]
  descricao varchar(255)
}

Table menus_sistema {
  id int [pk, increment]
  codigo varchar(50) [not null, unique]
  nome varchar(100) [not null]
  icone varchar(100)
  url varchar(255)
  ativo boolean [not null, default: true]
}

Table utilizadores {
  id int [pk, increment]
  codigo varchar(30) [not null, unique]
  nome varchar(150) [not null]
  cartao_cidadao varchar(20) [not null, unique]
  email varchar(150) [not null, unique]
  telefone varchar(30)
  servico varchar(120)
  tipo_id int [not null]
  estado varchar(30) [not null, default: "Ativo"]
  username varchar(80) [not null, unique]
  password_hash varchar(255) [not null]
  data_ativacao date
  validade_acesso date
  ultimo_acesso datetime
  observacoes text
  isActive boolean [not null, default: true]
  criado_em datetime [not null]
  atualizado_em datetime [not null]
}

Table utilizador_permissoes {
  id int [pk, increment]
  utilizador_id int [not null]
  menu_id int [not null]
  pode_aceder boolean [not null, default: false]
}

Table localizacoes {
  id int [pk, increment]
  codigo varchar(30) [not null, unique]
  departamento varchar(150) [not null]
  edificio varchar(100) [not null]
  piso varchar(30) [not null]
  sala varchar(80) [not null]
  tipo_espaco varchar(80) [not null]
  responsavel varchar(150)
  estado varchar(30) [not null, default: "Ativa"]
  capacidade_equipamentos int
  equipamentos_previstos int
  permite_equipamentos_criticos boolean [not null, default: false]
  observacoes text
  isActive boolean [not null, default: true]
  criado_em datetime [not null]
  atualizado_em datetime [not null]
}

Table categorias_equipamento {
  id int [pk, increment]
  nome varchar(100) [not null, unique]
  descricao varchar(255)
}

Table tipos_entrada {
  id int [pk, increment]
  nome varchar(50) [not null, unique]
}

Table estados_equipamento {
  id int [pk, increment]
  nome varchar(50) [not null, unique]
}

Table criticidades {
  id int [pk, increment]
  nome varchar(50) [not null, unique]
  descricao varchar(255)
}

Table equipamentos {
  id int [pk, increment]
  codigo varchar(30) [not null, unique]
  designacao varchar(150) [not null]
  categoria_id int [not null]
  fabricante varchar(120) [not null]
  modelo varchar(120) [not null]
  numero_serie varchar(120) [not null]
  ano_fabrico year
  data_aquisicao date
  custo_aquisicao decimal(12,2)
  tipo_entrada_id int
  estado_id int [not null]
  criticidade_id int [not null]
  localizacao_id int [not null]
  operacional boolean [not null, default: true]
  observacoes text
  isActive boolean [not null, default: true]
  criado_em datetime [not null]
  atualizado_em datetime [not null]
}

Table acessorios {
  id int [pk, increment]
  equipamento_id int [not null]
  codigo varchar(30) [not null, unique]
  nome varchar(150) [not null]
  tipo varchar(100)
  numero_serie varchar(120)
  estado_id int [not null]
  requer_manutencao boolean [not null, default: false]
  requer_calibracao boolean [not null, default: false]
  proxima_intervencao date
  observacoes text
  isActive boolean [not null, default: true]
}

Table fornecedor_tipos {
  id int [pk, increment]
  nome varchar(80) [not null, unique]
}

Table fornecedores {
  id int [pk, increment]
  codigo varchar(30) [not null, unique]
  nome_empresa varchar(180) [not null]
  nif varchar(20) [not null, unique]
  email varchar(150) [not null]
  telefone varchar(30)
  website varchar(255)
  pessoa_contacto varchar(150)
  telefone_contacto varchar(30)
  email_contacto varchar(150)
  cargo_contacto varchar(100)
  morada varchar(255)
  codigo_postal varchar(20)
  localidade varchar(100)
  pais varchar(80) [not null, default: "Portugal"]
  estado varchar(30) [not null, default: "Ativo"]
  contrato varchar(100)
  observacoes text
  isActive boolean [not null, default: true]
  criado_em datetime [not null]
  atualizado_em datetime [not null]
}

Table fornecedor_tipo_assoc {
  fornecedor_id int [not null]
  tipo_id int [not null]

  indexes {
    (fornecedor_id, tipo_id) [pk]
  }
}

Table equipamento_fornecedor {
  id int [pk, increment]
  equipamento_id int [not null]
  fornecedor_id int [not null]
  tipo_id int [not null]
  data_inicio date
  data_fim date
  observacoes text
}

Table documento_tipos {
  id int [pk, increment]
  nome varchar(100) [not null, unique]
}

Table documentos {
  id int [pk, increment]
  tipo_id int [not null]
  nome varchar(180) [not null]
  data_documento date
  data_validade date
  equipamento_id int
  acessorio_id int
  fornecedor_id int
  ficheiro_nome varchar(255)
  caminho_ficheiro varchar(255)
  observacoes text
  isActive boolean [not null, default: true]
  criado_por int
  criado_em datetime [not null]
}

Table garantias {
  id int [pk, increment]
  equipamento_id int [not null]
  fornecedor_id int
  documento_id int
  data_inicio date [not null]
  data_fim date [not null]
  entidade_responsavel varchar(150)
  observacoes text
  isActive boolean [not null, default: true]
}

Table contratos_manutencao {
  id int [pk, increment]
  equipamento_id int
  fornecedor_id int [not null]
  documento_id int
  numero_contrato varchar(80)
  tipo_contrato varchar(100) [not null]
  periodicidade varchar(80)
  data_inicio date
  data_fim date
  estado varchar(30) [not null, default: "Ativo"]
  observacoes text
  isActive boolean [not null, default: true]
}

Table procedimento_tipos {
  id int [pk, increment]
  nome varchar(80) [not null, unique]
}

Table procedimento_estados {
  id int [pk, increment]
  nome varchar(80) [not null, unique]
}

Table pedidos_calibracao_manutencao {
  id int [pk, increment]
  codigo varchar(30) [not null, unique]
  equipamento_id int [not null]
  acessorio_id int
  procedimento_tipo_id int [not null]
  fornecedor_id int
  tecnico_responsavel_id int
  data_pedido date [not null]
  data_prevista date
  data_conclusao date
  estado_id int [not null]
  observacoes text
  isActive boolean [not null, default: true]
  criado_em datetime [not null]
  atualizado_em datetime [not null]
}

Table historico_estados_equipamento {
  id int [pk, increment]
  equipamento_id int [not null]
  estado_anterior_id int
  estado_novo_id int [not null]
  utilizador_id int
  data_alteracao datetime [not null]
  observacoes text
}

Table conteudos_publicos {
  id int [pk, increment]
  chave varchar(100) [not null, unique]
  secao varchar(80) [not null]
  titulo varchar(180)
  texto text
  imagem varchar(255)
  url varchar(255)
  ordem int [not null, default: 0]
  ativo boolean [not null, default: true]
  atualizado_por int
  atualizado_em datetime [not null]
}

Ref: utilizadores.tipo_id > utilizador_tipos.id
Ref: utilizador_permissoes.utilizador_id > utilizadores.id
Ref: utilizador_permissoes.menu_id > menus_sistema.id

Ref: equipamentos.categoria_id > categorias_equipamento.id
Ref: equipamentos.tipo_entrada_id > tipos_entrada.id
Ref: equipamentos.estado_id > estados_equipamento.id
Ref: equipamentos.criticidade_id > criticidades.id
Ref: equipamentos.localizacao_id > localizacoes.id

Ref: acessorios.equipamento_id > equipamentos.id
Ref: acessorios.estado_id > estados_equipamento.id

Ref: fornecedor_tipo_assoc.fornecedor_id > fornecedores.id
Ref: fornecedor_tipo_assoc.tipo_id > fornecedor_tipos.id

Ref: equipamento_fornecedor.equipamento_id > equipamentos.id
Ref: equipamento_fornecedor.fornecedor_id > fornecedores.id
Ref: equipamento_fornecedor.tipo_id > fornecedor_tipos.id

Ref: documentos.tipo_id > documento_tipos.id
Ref: documentos.equipamento_id > equipamentos.id
Ref: documentos.acessorio_id > acessorios.id
Ref: documentos.fornecedor_id > fornecedores.id
Ref: documentos.criado_por > utilizadores.id

Ref: garantias.equipamento_id > equipamentos.id
Ref: garantias.fornecedor_id > fornecedores.id
Ref: garantias.documento_id > documentos.id

Ref: contratos_manutencao.equipamento_id > equipamentos.id
Ref: contratos_manutencao.fornecedor_id > fornecedores.id
Ref: contratos_manutencao.documento_id > documentos.id

Ref: pedidos_calibracao_manutencao.equipamento_id > equipamentos.id
Ref: pedidos_calibracao_manutencao.acessorio_id > acessorios.id
Ref: pedidos_calibracao_manutencao.procedimento_tipo_id > procedimento_tipos.id
Ref: pedidos_calibracao_manutencao.fornecedor_id > fornecedores.id
Ref: pedidos_calibracao_manutencao.tecnico_responsavel_id > utilizadores.id
Ref: pedidos_calibracao_manutencao.estado_id > procedimento_estados.id

Ref: historico_estados_equipamento.equipamento_id > equipamentos.id
Ref: historico_estados_equipamento.estado_anterior_id > estados_equipamento.id
Ref: historico_estados_equipamento.estado_novo_id > estados_equipamento.id
Ref: historico_estados_equipamento.utilizador_id > utilizadores.id

Ref: conteudos_publicos.atualizado_por > utilizadores.id
